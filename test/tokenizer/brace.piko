

arr[index]

function(arg1, arg2, arg3)

fn abc[T1, T2](arg1: T1, arg2: T1, arg3: T2) -> T2 {
    return func(arg1, arg2, arg3)
}


fn complex[T1, T2](arg1: T1, arg2: T1, arg3: T2) -> T2 {
    if (arg1 > arg2) {
        return func(arg1, arg2, arg3)
    } else if arg2 > arg1 {
        return func(arg2, arg1, arg3)
    } else if ((arg1 >= arg2)and(arg2 >= arg1)) {
        return func(( arg1+arg2 ), arg2, arg3)
    } else {
        return arg3
    }
}
